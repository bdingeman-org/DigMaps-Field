# DigMaps Field — fastlane lanes for the Trio-style "browser build".
# Uses the SAME six secrets every DIY browser-built app shares:
#   TEAMID, FASTLANE_ISSUER_ID, FASTLANE_KEY_ID, FASTLANE_KEY, GH_PAT, MATCH_PASSWORD
# Certificates/profiles live in the user's private Match-Secrets repo (created
# by the validate_secrets workflow if missing) — same repo Trio uses.

default_platform(:ios)

TEAMID              = ENV["TEAMID"]
GH_PAT              = ENV["GH_PAT"]
FASTLANE_KEY_ID     = ENV["FASTLANE_KEY_ID"]
FASTLANE_ISSUER_ID  = ENV["FASTLANE_ISSUER_ID"]
FASTLANE_KEY        = ENV["FASTLANE_KEY"]
GITHUB_REPO_OWNER   = ENV["GITHUB_REPOSITORY_OWNER"]

BUNDLE_ID = "org.digmaps.#{TEAMID}.field".freeze
MATCH_URL = "https://github.com/#{GITHUB_REPO_OWNER}/Match-Secrets.git".freeze

def api_key
  app_store_connect_api_key(
    key_id: FASTLANE_KEY_ID,
    issuer_id: FASTLANE_ISSUER_ID,
    key_content: FASTLANE_KEY
  )
end

def match_auth
  Base64.strict_encode64("#{GITHUB_REPO_OWNER}:#{GH_PAT}")
end

def spaceship_login
  Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
    key_id: FASTLANE_KEY_ID,
    issuer_id: FASTLANE_ISSUER_ID,
    key: FASTLANE_KEY
  )
end

platform :ios do
  desc "Check that the six secrets work (App Store Connect + Match-Secrets access)"
  lane :validate_secrets do
    UI.user_error!("TEAMID secret is missing") if TEAMID.to_s.strip.empty?
    UI.user_error!("MATCH_PASSWORD secret is missing") if ENV["MATCH_PASSWORD"].to_s.strip.empty?
    spaceship_login
    Spaceship::ConnectAPI::BundleId.all(filter: {}) # real API round-trip
    UI.success("App Store Connect API key works.")
  end

  desc "Register the org.digmaps.<TEAMID>.field App ID (run once)"
  lane :identifiers do
    spaceship_login
    existing = Spaceship::ConnectAPI::BundleId.all.find { |b| b.identifier == BUNDLE_ID }
    if existing
      UI.success("App ID #{BUNDLE_ID} already registered.")
    else
      Spaceship::ConnectAPI::BundleId.create(name: "DigMaps Field", identifier: BUNDLE_ID)
      UI.success("Registered App ID #{BUNDLE_ID}.")
    end
  end

  desc "Build DigMaps Field and push it to TestFlight"
  lane :build_digmaps_field do
    setup_ci

    match(
      type: "appstore",
      app_identifier: [BUNDLE_ID],
      git_url: MATCH_URL,
      git_basic_authorization: match_auth,
      api_key: api_key,
      readonly: false
    )

    profile_name = lane_context.dig(
      SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING, BUNDLE_ID
    )

    gym(
      project: "DigMapsField.xcodeproj",
      scheme: "DigMapsField",
      configuration: "Release",
      export_method: "app-store",
      output_name: "DigMapsField.ipa",
      xcargs: [
        "DEVELOPER_TEAM_ID=#{TEAMID}",
        "PROVISIONING_PROFILE_SPECIFIER='#{profile_name}'",
        "CODE_SIGN_IDENTITY='Apple Distribution'",
        "CURRENT_PROJECT_VERSION=#{ENV.fetch('GITHUB_RUN_NUMBER', '1')}"
      ].join(" "),
      export_options: {
        provisioningProfiles: { BUNDLE_ID => profile_name }
      }
    )

    pilot(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end

  desc "Delete and re-create certs/profiles if signing gets wedged"
  lane :nuke_certs do
    match_nuke(
      type: "appstore",
      git_url: MATCH_URL,
      git_basic_authorization: match_auth,
      api_key: api_key,
      skip_confirmation: true
    )
  end
end
